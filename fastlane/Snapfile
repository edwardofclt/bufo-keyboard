# Devices to capture. App Store Connect (early 2025) requires:
#   * one iPhone set — 6.9" (16 Pro Max) preferred, 6.5" (15 Pro Max) fallback
#   * one iPad set   — 13" (iPad Pro M4) preferred, 12.9" (6th gen) fallback
# Apple scales these down for older device sizes automatically.
devices([
  "iPhone 16 Pro Max",                        # 6.9" — Xcode 16+
  "iPhone 15 Pro Max",                        # 6.7" — Xcode 15+
  "iPad Pro 13-inch (M4)",                    # 13"  — Xcode 16+
  "iPad Pro (12.9-inch) (6th generation)",    # 12.9" — Xcode 14+
])

languages([
  "en-US",
])

scheme("BufoKeyboard")

# Only run the screenshot tests, not anything else in the scheme.
only_testing(["BufoKeyboardUITests/BufoKeyboardScreenshots"])

output_directory("./fastlane/screenshots")

# Wipe previous run so the screenshots dir is always current.
clear_previous_screenshots(true)

# Replaces the status bar with a clean one (9:41, full battery/signal).
override_status_bar(true)

